# ── Serveur ──────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://dakarauto-frontend.vercel.app

# ── Firebase Admin ────────────────────────────────────
# Colle ici le contenu JSON de ta clé de service Firebase
# (téléchargeable depuis Console Firebase → Paramètres → Comptes de service)
FIREBASE_PROJECT_ID=COLLE_TON_PROJECT_ID
FIREBASE_CLIENT_EMAIL=COLLE_TON_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="COLLE_TA_PRIVATE_KEY"

# ── Twilio WhatsApp ───────────────────────────────────
TWILIO_ACCOUNT_SID=COLLE_TON_ACCOUNT_SID
TWILIO_AUTH_TOKEN=COLLE_TON_AUTH_TOKEN
